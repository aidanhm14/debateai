{
  "manifest_version": 3,
  "name": "Counter: Oral Exam Trainer (by DebateAI)",
  "short_name": "Counter",
  "version": "0.9.0",
  "description": "Defend your work out loud. Or lint any argument for claim, warrant, and impact. Viva, oral exam, CBSE/ICSE, JEE/NEET prep.",
  "author": "DebateAI",
  "homepage_url": "https://debateai.com",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "activeTab",
    "storage",
    "clipboardRead",
    "identity",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "https://debateai.com/*",
    "https://debatethedevil.com/*",
    "https://docs.googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "oauth2": {
    "client_id": "PASTE_YOUR_GOOGLE_OAUTH_CLIENT_ID_HERE.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Counter (oral exam trainer)",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "debate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Cross-examine me on the selected passage"
    },
    "rebut-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Defend the selected argument out loud"
    },
    "lint-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Lint the selected argument for claim, warrant, and impact"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the Counter side panel"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
