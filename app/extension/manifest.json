{
  "manifest_version": 3,
  "name": "Counter: Oral Exam Trainer (by DebateAI)",
  "short_name": "Counter",
  "version": "0.2.0",
  "description": "Highlight any passage in Docs, articles, or PDFs. The AI cross-examines you out loud. Practice school orals, vivas, college interviews, and thesis defenses.",
  "permissions": [
    "sidePanel",
    "contextMenus",
    "activeTab",
    "scripting",
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "https://debateai.com/*",
    "https://debatethedevil.com/*",
    "https://*.debateai.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Counter (oral exam trainer)",
    "default_icon": {
      "192": "icons/icon-192.png",
      "512": "icons/icon-512.png"
    }
  },
  "icons": {
    "192": "icons/icon-192.png",
    "512": "icons/icon-512.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "debate-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Cross-examine me on the selected passage"
    },
    "rebut-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+R",
        "mac": "Command+Shift+R"
      },
      "description": "Defend the selected argument out loud"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+B",
        "mac": "Command+Shift+B"
      }
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
