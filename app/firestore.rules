rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // Guests (Firebase anonymous auth, enabled 2026-06-12 so /spar
    // matchmaking works without a Google account) count as signed in
    // everywhere EXCEPT waitlist posting, which keeps the named-account
    // bar so the public open-invite board can't be spammed by throwaway
    // guests. DMs were opened to guests 2026-06-16: a guest can only
    // reach a thread with someone they matched with or a named waitlist
    // poster who opted into DMs, so the spam surface is narrow, and a
    // guest who matches needs to coordinate the round somehow.
    function isNamedAccount() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAtlasAdmin() {
      return isSignedIn()
        && (request.auth.uid == 'Dh2EqyEdPGX2cCOAxLzMk9nAlUV2'
            || (exists(/databases/$(database)/documents/user_profiles/$(request.auth.uid))
                && get(/databases/$(database)/documents/user_profiles/$(request.auth.uid)).data.isAdmin == true));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAuthor() {
      return isSignedIn() && request.auth.uid == resource.data.authorUid;
    }

    function incomingIsAuthor() {
      return isSignedIn() && request.auth.uid == request.resource.data.authorUid;
    }

    function stringUnder(field, maxBytes) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() <= maxBytes;
    }

    // ── user_cases ───────────────────────────────────────────────────
    // Documents keyed by uid OR containing a uid field.
    match /user_cases/{docId} {
      allow read:   if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && (docId == request.auth.uid
                        || request.resource.data.uid == request.auth.uid)
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow update: if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid)
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow delete: if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid);
    }

    // ── user_profiles ────────────────────────────────────────────────
    // Doc ID = uid. Users can only touch their own profile.
    match /user_profiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── shared_cases ─────────────────────────────────────────────────
    // Anyone authenticated can read. Only the author can write/delete.
    // 'visibility' field gates the public disclosure board: 'team'
    // (default — keep within team scope) or 'public' (visible to anyone
    // signed-in via the /disclosures community page). The constraint
    // lets us trust the value when the disclosure UI queries by it.
    function validVisibility() {
      return !('visibility' in request.resource.data)
          || request.resource.data.visibility in ['team', 'public', 'private'];
    }
    match /shared_cases/{caseId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && incomingIsAuthor()
                    && validVisibility()
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200))
                    && (!('output' in request.resource.data)
                        || stringUnder('output', 51200));
      // Voting + vote-count maintenance: the parent doc's voteScore +
      // voteCount are atomically updated by the voting client. Allow
      // ANY signed-in user to update those two fields (plus the
      // existing author-only rule for everything else). Practical
      // effect: voters can bump the score, but can't rewrite the case.
      function onlyVoteFieldsChanged() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return changed.hasOnly(['voteScore', 'voteCount']);
      }
      allow update: if isSignedIn()
                    && (
                      (isAuthor()
                        && incomingIsAuthor()
                        && validVisibility()
                        && (!('content' in request.resource.data)
                            || stringUnder('content', 51200))
                        && (!('output' in request.resource.data)
                            || stringUnder('output', 51200)))
                      || onlyVoteFieldsChanged()
                    );
      allow delete: if isAuthor();

      // Per-user vote records. Doc id MUST be the voter's uid so each
      // user gets exactly one vote. Vote value is +1 (up), -1 (down),
      // or 0 (cleared). Author-side rule layered to prevent self-vote
      // gaming on disclosures.
      match /votes/{voterUid} {
        allow read:   if isSignedIn();
        allow create, update: if isSignedIn()
                      && voterUid == request.auth.uid
                      && request.resource.data.vote in [-1, 0, 1];
        allow delete: if isSignedIn() && voterUid == request.auth.uid;
      }
    }

    // ── public_rounds ────────────────────────────────────────────────
    // Published debate rounds at /r/{id}. Render + publish both go
    // through Netlify Functions using the admin SDK (which bypasses
    // these rules), so client-side writes are explicitly denied here
    // to prevent users from spoofing rounds onto the public corpus.
    // Reads are open so that even a future client-side fetch (for an
    // embed widget or a /disclosures-style listing) works without
    // re-architecting.
    //
    // Authors can delete their own rounds to take a publication back.
    match /public_rounds/{roundId} {
      allow read:   if true;
      allow create: if false;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.authorUid == request.auth.uid;
    }

    // ── forum_posts ──────────────────────────────────────────────────
    // Threaded discussion under /community. Top-level threads have
    // parentId == null; replies have parentId == <thread doc id>.
    // Anyone authenticated can read. Only the author can write/delete
    // the thread/reply itself. Vote counts on the parent doc are
    // updatable by anyone signed in (same pattern as shared_cases).
    function forumOnlyVoteFieldsChanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['voteScore', 'voteCount', 'replyCount']);
    }
    match /forum_posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && incomingIsAuthor()
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow update: if isSignedIn()
                    && (
                      (isAuthor() && incomingIsAuthor()
                       && (!('content' in request.resource.data)
                           || stringUnder('content', 51200)))
                      || forumOnlyVoteFieldsChanged()
                    );
      allow delete: if isAuthor();

      match /votes/{voterUid} {
        allow read:   if isSignedIn();
        allow create, update: if isSignedIn()
                      && voterUid == request.auth.uid
                      && request.resource.data.vote in [-1, 0, 1];
        allow delete: if isSignedIn() && voterUid == request.auth.uid;
      }
    }

    // ── judge_pool ───────────────────────────────────────────────────
    // Anyone authenticated can read. Users can only write their own entries.
    match /judge_pool/{docId} {
      allow read:  if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── live_debates ─────────────────────────────────────────────────
    // Anyone authenticated can read. Only the creator can delete.
    match /live_debates/{debateId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.creatorUid == request.auth.uid;
      // Creator edits freely; everyone else can only touch the
      // participants array (join/leave). Was `if isSignedIn()`, which
      // made every debate world-writable.
      allow update: if isSignedIn()
                    && (
                      (('creatorUid' in resource.data)
                        && resource.data.creatorUid == request.auth.uid)
                      || request.resource.data.diff(resource.data)
                           .affectedKeys().hasOnly(['participants'])
                    );
      allow delete: if isSignedIn()
                    && resource.data.creatorUid == request.auth.uid;
    }

    // ── live_rounds ──────────────────────────────────────────────────
    // Per-room synced state for the AI-judged 2-human round flow:
    // motion, format, speaker names + UIDs, completed speech log,
    // current speech index, and the AI ballot once generated. Doc ID
    // is the deterministic room slug (DebateIt-<challengeId> or a
    // randomly-generated room name shared via URL).
    //
    // Read = any signed-in user (links are shared between speakers,
    // and we don't have a backend introduction step yet so the URL is
    // the entry control). Update = any signed-in user — the
    // participants discover each other dynamically by both landing on
    // the same URL. Tighten to participant-only writes once we wire
    // the server-side challenge accept flow.
    match /live_rounds/{roomId} {
      // Public read: anyone (signed in or not) can watch a round and
      // read its ballot/RFD. Round docs hold motion, speeches, and the
      // AI ballot — no PII (emails live in live_challenge_contacts).
      // Writes still require sign-in (and participant checks below).
      allow read:   if true;
      allow create: if isSignedIn()
                    && stringUnder('motion', 4096);

      // The consent map can only be touched by the consenting user
      // for their own UID key. Computes the affected keys of the
      // leaderboardConsent map between old and new doc state and
      // requires every changed key to equal the writer's auth.uid.
      // No leaderboardConsent change at all → returns true so it
      // doesn't block currentTimer / speech-log updates.
      function leaderboardConsentChangeIsOwnUid() {
        let oldMap = resource.data.get('leaderboardConsent', {});
        let newMap = request.resource.data.get('leaderboardConsent', {});
        let changed = newMap.diff(oldMap).affectedKeys();
        return changed.size() == 0 || changed.hasOnly([request.auth.uid]);
      }

      // Participant-only writes once the round has both UIDs locked
      // in (i.e., a posted+accepted challenge). Spectators land here
      // signed-in but match neither side, so they can read the round
      // but can't mutate it. Plus: even between participants, the
      // leaderboardConsent map is per-UID — neither side can flip
      // the other's consent flag to bypass dual consent.
      // Legacy rounds without proUid/conUid (direct-link/local-only
      // flows) keep the open update so they don't break.
      allow update: if isSignedIn()
                    && leaderboardConsentChangeIsOwnUid()
                    && (
                      !('proUid' in resource.data)
                      || !('conUid' in resource.data)
                      || resource.data.proUid == request.auth.uid
                      || resource.data.conUid == request.auth.uid
                    );
      allow delete: if false;

      // Watcher presence — live "N watching" count for spar rounds.
      // Public read (mirrors the round). Each watcher writes only their
      // OWN heartbeat doc (path id == uid), guests included. No PII
      // beyond a display name + timestamp; stale docs age out of the
      // count client-side at 75s.
      match /watchers/{watcherUid} {
        allow read: if true;
        allow create, update, delete: if isSignedIn()
                      && watcherUid == request.auth.uid;
      }

      // Join requests — a visitor on the landing "live now" feed asks a
      // debater in this room to let them in. Doc id == requester uid.
      // Public read (requester polls own status; participants list all
      // pending). The requester writes only their OWN doc and only at
      // status 'pending'/'withdrawn' — they can't self-admit. A
      // participant (pro/con on the parent round) resolves any request
      // to accepted/rejected. A get() reads the parent round to learn
      // who the participants are.
      match /joinRequests/{reqUid} {
        function parentRound() {
          return get(/databases/$(database)/documents/live_rounds/$(roomId)).data;
        }
        function isRoundParticipant() {
          return isSignedIn()
            && (parentRound().get('proUid', '') == request.auth.uid
             || parentRound().get('conUid', '') == request.auth.uid);
        }
        allow read: if true;
        allow create, update: if isSignedIn() && (
          (reqUid == request.auth.uid
            && request.resource.data.status in ['pending', 'withdrawn'])
          || (isRoundParticipant()
            && request.resource.data.status in ['pending', 'accepted', 'rejected'])
        );
        allow delete: if isSignedIn()
                      && (reqUid == request.auth.uid || isRoundParticipant());
      }
    }

    // ── matchmaking_queue ────────────────────────────────────────────
    // Ephemeral queue for the /spar matchmaking flow. Doc ID === uid
    // so each user has exactly one queue entry. Rule shape:
    //  - read: any signed-in user (so the polling client can see who
    //    else is waiting in their format)
    //  - create: only your own doc; status must be 'waiting'
    //  - update: only your own doc. Pairing moved server-side to
    //    spar-pair (admin SDK bypasses these rules) on 2026-05-18; the
    //    old client-transaction "peer match transition" allowance let
    //    any signed-in user flip any waiting peer to matched with an
    //    arbitrary room (the victim's own-doc listener auto-navigates
    //    there ~1s later), so it was removed as pure attack surface.
    //  - delete: only your own doc (pagehide cleanup, cancel).
    match /matchmaking_queue/{queueUid} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && queueUid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.status == 'waiting';
      allow update: if isSignedIn() && queueUid == request.auth.uid;
      allow delete: if isSignedIn() && queueUid == request.auth.uid;
    }

    // ── live_challenges ──────────────────────────────────────────────
    // Cross-user challenge board — replaces the localStorage-only
    // /live.html state. Doc has: posterUid, motion, format, side,
    // scheduledAt, reveal, handle, etc. Anyone signed in can read
    // (so the board lists challenges across users). Only the poster
    // can delete their own challenge.
    match /live_challenges/{challengeId} {
      // Public read: the board + archive of past rounds are viewable by
      // anyone, signed in or not. Challenge docs hold no PII (poster
      // email moved to live_challenge_contacts). Posting/accepting are
      // writes and still require sign-in.
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.posterUid == request.auth.uid
                    && stringUnder('motion', 1024);
      // Update paths: the poster can edit their own challenge freely.
      // A non-poster can ONLY touch the accept slot, and only as
      // themselves: claim it (accepterUid = own uid, slot empty or
      // already theirs) or clear their own acceptance (field deletes).
      // The old `allow update: if isSignedIn()` let anyone rewrite
      // anyone's challenge, including posterUid, then pass the delete
      // rule — a two-step takeover of the public board.
      allow update: if isSignedIn()
                    && (
                      resource.data.posterUid == request.auth.uid
                      || (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['accepterUid', 'accepterName', 'acceptedAt'])
                        && (
                          // accept: claim the slot as yourself, no takeover
                          (('accepterUid' in request.resource.data)
                            && request.resource.data.accepterUid == request.auth.uid
                            && (!('accepterUid' in resource.data)
                                || resource.data.accepterUid == request.auth.uid))
                          // un-accept: only the current accepter clears it
                          || (!('accepterUid' in request.resource.data)
                            && ('accepterUid' in resource.data)
                            && resource.data.accepterUid == request.auth.uid)
                        )
                      )
                    );
      allow delete: if isSignedIn()
                    && resource.data.posterUid == request.auth.uid;
    }

    // ── live_challenge_contacts ──────────────────────────────────────
    // Private companion to live_challenges. Stores posterEmail,
    // accepterEmail, and the accepter's freeform contact (phone/email).
    // These USED TO live on live_challenges itself, which is publicly
    // readable by every signed-in user — leaking emails to the whole
    // userbase. Moved here so only the matched parties can read.
    //
    // Doc id matches the parent live_challenges/{challengeId}. Doc has:
    //   { challengeId, posterUid, posterEmail, accepterUid?,
    //     accepterEmail?, accepterContact?, createdAt, acceptedAt? }
    //
    // Read: only the poster or the accepter on this match.
    // Create: poster only (during postChallenge), must self-author.
    // Update: poster (extending their own fields) or accepter (writing
    //   their accept fields, must self-author them).
    // Delete: poster (when deleting their challenge).
    match /live_challenge_contacts/{challengeId} {
      allow read:   if isSignedIn()
                    && (resource.data.posterUid == request.auth.uid
                        || resource.data.accepterUid == request.auth.uid);
      allow create: if isSignedIn()
                    && request.resource.data.posterUid == request.auth.uid;
      // Update is the accept path (or poster amending their own row).
      // Allow if the writer is the existing poster OR if the writer is
      // setting/clearing themselves as the accepter.
      allow update: if isSignedIn()
                    && (resource.data.posterUid == request.auth.uid
                        || request.resource.data.accepterUid == request.auth.uid
                        || resource.data.accepterUid == request.auth.uid);
      allow delete: if isSignedIn()
                    && resource.data.posterUid == request.auth.uid;
    }

    // ── saved_rounds ─────────────────────────────────────────────────
    // User saves a completed live round to their record (motion,
    // format, ballot, speeches). Doc ID = uid + '_' + room so the
    // same user re-saving the same round just updates the doc
    // instead of creating duplicates. Reads + writes scoped to the
    // owning user.
    match /saved_rounds/{docId} {
      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── referral_credits ─────────────────────────────────────────────
    // Server-side only. Deny all client access.
    match /referral_credits/{docId} {
      allow read, write: if false;
    }

    // ── learning_insights ────────────────────────────────────────────
    // Users can only write their own insights.
    match /learning_insights/{docId} {
      allow read:   if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── learning_counters ────────────────────────────────────────────
    // Doc ID = uid. Users can only read/write their own counter doc.
    match /learning_counters/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── teams ────────────────────────────────────────────────────────
    // Members can read; only owner can write the team doc.
    // Inlined ownership check (was isTeamOwner/isTeamMember helpers, but
    // isTeamMember referenced an undefined getTeamMemberByQuery and the
    // helpers added no clarity over a direct ownerUid comparison).
    match /teams/{teamId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;

      // members subcollection
      match /members/{memberId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
      }

      // invites subcollection
      match /invites/{inviteId} {
        allow read:   if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
      }

      // pendingInvites subcollection (alias kept for backward compat)
      match /pendingInvites/{inviteId} {
        allow read:   if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
      }
    }

    // ── team_members (top-level collection) ──────────────────────────
    // Server-managed primarily, but allow reads for team context.
    match /team_members/{docId} {
      allow read:  if isSignedIn();
      allow write: if false; // server-side only via Admin SDK
    }

    // ── usage_logs ───────────────────────────────────────────────────
    // Server-side only.
    match /usage_logs/{docId} {
      allow read, write: if false;
    }

    // ── early_cohort_signups ────────────────────────────────────────
    // Founding-cohort signup capture (/api/early-signup). Contains
    // emails — locked to server-side admin-SDK access only. The public
    // count counter goes through the GET path of the same function,
    // never a direct browser read.
    match /early_cohort_signups/{docId} {
      allow read, write: if false;
    }

    // ── debate_rounds ────────────────────────────────────────────────
    // Per-user history of completed AI rounds (motion, format, side, log,
    // feedback, ballot, speakerPoints). Doc ID convention: `${uid}_${roundId}`
    // so the same user re-saving the same round just merges instead of
    // creating duplicates. Reads + writes scoped to the owning user — these
    // are private histories, not the public leaderboard.
    match /debate_rounds/{docId} {
      allow read:   if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
      allow create: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*')
                    && stringUnder('motion', 4096);
      allow update: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
      allow delete: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
    }

    // ── leaderboard_entries ──────────────────────────────────────────
    // Slim, denormalized public board of completed-round results.
    // Public read so the /leaderboard page works for anonymous visitors
    // (it's a sign-in driver — users should see the board first, then
    // be prompted to claim their spot). Writes are owner-only and the
    // doc must contain the writer's uid so spoofing other users is
    // impossible. Doc ID convention: `${uid}_${roundId}` to match the
    // existing debate_rounds convention.
    match /leaderboard_entries/{docId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && stringUnder('motion', 1024)
                    && stringUnder('displayName', 100);
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── voice_rounds ─────────────────────────────────────────────────
    // Saved, revisitable voice-round records (ballot + full transcript +
    // stats). Written client-side by voice-debate.html on RFD generation.
    // Public read so a shared ballot link (/voice-rfd?id=) resolves for
    // anyone with the unguessable doc id — same privacy model as
    // certificates. Create is owner-only and the doc must carry the
    // writer's uid; rounds are immutable once written (no update/delete).
    match /voice_rounds/{roundId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && stringUnder('motion', 1024)
                    && stringUnder('rfd', 20000);
      allow update, delete: if false;
    }

    // ── waitlist_posts ───────────────────────────────────────────────
    // /spar left-rail "open invites" board. Anyone signed in can read
    // the board; you can only create/edit/delete your own post. Note
    // capped at 240 bytes to match the composer's maxlength.
    match /waitlist_posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isNamedAccount()
                    && request.resource.data.uid == request.auth.uid
                    && stringUnder('note', 240);
      allow update, delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── dm_threads ───────────────────────────────────────────────────
    // Private 1:1 DMs between two debaters (threadId = sorted uid pair).
    // Read/write gated to the two participants. On create we check the
    // INCOMING participants array (resource is null); on read/update we
    // check the EXISTING doc. update is intentionally open to either
    // participant so the sender can bump lastMessage + increment the
    // recipient's unread counter, and the recipient can zero their own
    // unread on read — both are participant-scoped writes.
    match /dm_threads/{threadId} {
      allow read, update: if isSignedIn()
                    && request.auth.uid in resource.data.participants;
      // Create is open to any signed-in user (named OR guest, since
      // 2026-06-16) as long as they put THEMSELVES in the participants
      // array — you can't fabricate a thread you're not in. The
      // participant gate is the real guard; named-only was dropped so a
      // guest who matched can actually message to set up the round.
      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;
      // Messages: only participants can read; only the author can post,
      // and only as themselves with a length-capped body. Guests allowed
      // (2026-06-16) — the fromUid==auth.uid + participant checks mean a
      // guest can only post as themselves into a thread they belong to.
      match /messages/{msgId} {
        allow read: if isSignedIn()
                    && request.auth.uid in
                       get(/databases/$(database)/documents/dm_threads/$(threadId)).data.participants;
        allow create: if isSignedIn()
                    && request.resource.data.fromUid == request.auth.uid
                    && request.auth.uid in
                       get(/databases/$(database)/documents/dm_threads/$(threadId)).data.participants
                    && stringUnder('text', 1000);
      }
    }

    // ── prospects ────────────────────────────────────────────────────
    // Lightweight email/phone capture for visitors who won't sign in
    // with Google. Anyone — signed-in OR anonymous — can create a doc;
    // nobody can read, list, update, or delete from the client. Admin
    // SDK in Netlify functions (log-prospect.mjs writes; admin-prospects.mjs
    // reads) bypasses these rules. admin-subscribers.mjs reads the separate
    // email_signups collection, NOT this one.
    //
    // Schema (enforced inline):
    //   { email: string ≤254, phone: string ≤18, source: string ≤80,
    //     ua: string ≤240, locale: string ≤16, page: string ≤240,
    //     ref: string ≤240, createdAt: serverTimestamp,
    //     clientCreatedAt: number? }
    //
    // No auth required because the whole point of this collection is to
    // capture leads from users who refused the Google sign-in step.
    match /prospects/{docId} {
      allow read, list, update, delete: if false;
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$')
                    && (!('phone' in request.resource.data)
                        || (request.resource.data.phone is string
                            && request.resource.data.phone.size() <= 18))
                    && (!('source' in request.resource.data)
                        || (request.resource.data.source is string
                            && request.resource.data.source.size() <= 80))
                    && (!('ua' in request.resource.data)
                        || (request.resource.data.ua is string
                            && request.resource.data.ua.size() <= 240))
                    && (!('locale' in request.resource.data)
                        || (request.resource.data.locale is string
                            && request.resource.data.locale.size() <= 16))
                    && (!('page' in request.resource.data)
                        || (request.resource.data.page is string
                            && request.resource.data.page.size() <= 240))
                    && (!('ref' in request.resource.data)
                        || (request.resource.data.ref is string
                            && request.resource.data.ref.size() <= 240));
    }

    // ── certificates / user_certificates ─────────────────────────────
    // Public credential artifacts for /verify + /profile +
    // /communication-profile. Writes only come from /api/create-cert
    // (server-side admin SDK bypasses these rules), so the rule says
    // "no client writes ever." These blocks previously lived ONLY in
    // the console (hand-paste, documented in profile.html) — codified
    // here so a rules deploy can't wipe them.
    match /certificates/{id} {
      allow read:  if true;
      allow write: if false;
    }
    match /user_certificates/{uid} {
      allow read:  if true;
      allow write: if false;
    }

    // ── users ────────────────────────────────────────────────────────
    // Admin-set per-user flags (e.g. `verified` for the community
    // badge). Written only via admin SDK; clients read their own doc.
    match /users/{uid} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── email_signups ────────────────────────────────────────────────
    // "Stay in the loop" capture on /app and the leaderboard empty
    // state. Create-only, same posture as prospects: anyone can add a
    // valid email, nobody reads from the client (admin-subscribers.mjs
    // reads via admin SDK). Without this block every signup was
    // silently dropped while the UI said "Subscribed!".
    match /email_signups/{docId} {
      allow read, update, delete: if false;
      allow create: if request.resource.data.email is string
                    && request.resource.data.email.size() > 0
                    && request.resource.data.email.size() <= 254
                    && request.resource.data.email.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]{2,}$')
                    && (!('source' in request.resource.data)
                        || (request.resource.data.source is string
                            && request.resource.data.source.size() <= 80));
    }

    // ── feedback ─────────────────────────────────────────────────────
    // In-app feedback modal + logFeedback quality signals. Create-only
    // (admin SDK reads). Anonymous allowed — the modal writes
    // uid:'anonymous' for signed-out users. Without this block the
    // modal always threw "Error sending feedback."
    match /feedback/{docId} {
      allow read, update, delete: if false;
      allow create: if (!('description' in request.resource.data)
                        || (request.resource.data.description is string
                            && request.resource.data.description.size() <= 8000))
                    && (!('screenshots' in request.resource.data)
                        || (request.resource.data.screenshots is list
                            && request.resource.data.screenshots.size() <= 2));
    }

    // ── votes (collection group) ─────────────────────────────────────
    // Authorizes the collectionGroup('votes') hydration on /community:
    // path-scoped vote rules above never authorize group queries. The
    // client queries where('uid','==', own uid), which provably
    // matches this rule. Vote docs written before the `uid` field was
    // added simply don't pre-light arrows; new votes do.
    match /{path=**}/votes/{voterUid} {
      allow read: if isSignedIn()
                  && resource.data.uid == request.auth.uid;
    }

    // ── atlas_pipeline (Debate Atlas shared outreach tracker) ────────
    // One doc per program (slug id). Read is public so the /atlas map can
    // be shared with investors as a live link. Writes need a signed-in
    // named (non-anonymous) account, are self-attributed via `by`, and
    // the status is enum-validated. The URL is unlisted; tighten to an
    // explicit editor allowlist later if the team grows.
    match /atlas_pipeline/{slug} {
      allow read: if true;
      allow create, update: if isNamedAccount()
        && request.resource.data.status in ['prospect', 'contacted', 'partnered']
        && request.resource.data.by == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 160;
      allow delete: if isNamedAccount();
    }

    // ── atlas_submissions (community "add your program" pins) ────────
    // Signed-in named accounts add a pin (self-attributed, validated, in
    // range). Authors can edit/withdraw their own; atlas admins can
    // remove or verify any. Read is public so pins show on the map.
    match /atlas_submissions/{id} {
      allow read: if true;
      allow create: if isNamedAccount()
        && request.resource.data.by == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 160
        && (!('city' in request.resource.data) || (request.resource.data.city is string && request.resource.data.city.size() <= 120))
        && (!('country' in request.resource.data) || (request.resource.data.country is string && request.resource.data.country.size() <= 80))
        && request.resource.data.lat is number && request.resource.data.lat >= -85 && request.resource.data.lat <= 85
        && request.resource.data.lng is number && request.resource.data.lng >= -180 && request.resource.data.lng <= 180
        && request.resource.data.lvl in ['college', 'hs'];
      allow update: if isSignedIn() && (resource.data.by == request.auth.uid || isAtlasAdmin());
      allow delete: if isSignedIn() && (resource.data.by == request.auth.uid || isAtlasAdmin());
    }

    // ── atlas_members (debaters place themselves on the globe) ───────
    // One doc per user (keyed by uid). A signed-in named account writes
    // only its own member pin; anyone can read; admins can remove.
    match /atlas_members/{uid} {
      allow read: if true;
      allow write: if isNamedAccount() && uid == request.auth.uid
        && request.resource.data.name is string && request.resource.data.name.size() > 0 && request.resource.data.name.size() <= 80
        && request.resource.data.lat is number && request.resource.data.lat >= -85 && request.resource.data.lat <= 85
        && request.resource.data.lng is number && request.resource.data.lng >= -180 && request.resource.data.lng <= 180;
      allow delete: if isSignedIn() && (request.auth.uid == uid || isAtlasAdmin());
    }

    // ── Prediction market (predict_*) ────────────────────────────────
    // POINTS ONLY, server-authoritative. Every economy mutation goes through
    // the predict.mjs Netlify function (admin credentials, validated). Clients
    // can NEVER write balances, pools, payouts, or bets; they may only read
    // public market state, the public leaderboard, and their own balance.
    match /predict_markets/{room} {
      allow read:  if true;     // public market state (motion, pools, status, verdict)
      allow write: if false;    // opened / updated / settled only by the server
      match /bets/{betUid} {
        allow read:  if false;  // bets are blind; only the server function reads them
        allow write: if false;  // placed only via the server (atomic balance debit)
      }
    }
    match /predict_balances/{uid} {
      allow read:  if isOwner(uid);  // you can see your own points
      allow write: if false;         // server-authoritative
    }
    match /predict_leaderboard/{uid} {
      allow read:  if true;          // public skill ladder
      allow write: if false;         // server-authoritative
    }

    // ── Default deny ─────────────────────────────────────────────────
    // Any collection not explicitly listed above is denied.
  }
}
