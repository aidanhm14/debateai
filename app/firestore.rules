rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAuthor() {
      return isSignedIn() && request.auth.uid == resource.data.authorUid;
    }

    function incomingIsAuthor() {
      return isSignedIn() && request.auth.uid == request.resource.data.authorUid;
    }

    function stringUnder(field, maxBytes) {
      return request.resource.data[field] is string
          && request.resource.data[field].size() <= maxBytes;
    }

    // ── user_cases ───────────────────────────────────────────────────
    // Documents keyed by uid OR containing a uid field.
    match /user_cases/{docId} {
      allow read:   if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid);
      allow create: if isSignedIn()
                    && (docId == request.auth.uid
                        || request.resource.data.uid == request.auth.uid)
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow update: if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid)
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow delete: if isSignedIn()
                    && (docId == request.auth.uid
                        || resource.data.uid == request.auth.uid);
    }

    // ── user_profiles ────────────────────────────────────────────────
    // Doc ID = uid. Users can only touch their own profile.
    match /user_profiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── shared_cases ─────────────────────────────────────────────────
    // Anyone authenticated can read. Only the author can write/delete.
    // 'visibility' field gates the public disclosure board: 'team'
    // (default — keep within team scope) or 'public' (visible to anyone
    // signed-in via the /disclosures community page). The constraint
    // lets us trust the value when the disclosure UI queries by it.
    function validVisibility() {
      return !('visibility' in request.resource.data)
          || request.resource.data.visibility in ['team', 'public', 'private'];
    }
    match /shared_cases/{caseId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && incomingIsAuthor()
                    && validVisibility()
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      // Voting + vote-count maintenance: the parent doc's voteScore +
      // voteCount are atomically updated by the voting client. Allow
      // ANY signed-in user to update those two fields (plus the
      // existing author-only rule for everything else). Practical
      // effect: voters can bump the score, but can't rewrite the case.
      function onlyVoteFieldsChanged() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        return changed.hasOnly(['voteScore', 'voteCount']);
      }
      allow update: if isSignedIn()
                    && (
                      (isAuthor()
                        && incomingIsAuthor()
                        && validVisibility()
                        && (!('content' in request.resource.data)
                            || stringUnder('content', 51200)))
                      || onlyVoteFieldsChanged()
                    );
      allow delete: if isAuthor();

      // Per-user vote records. Doc id MUST be the voter's uid so each
      // user gets exactly one vote. Vote value is +1 (up), -1 (down),
      // or 0 (cleared). Author-side rule layered to prevent self-vote
      // gaming on disclosures.
      match /votes/{voterUid} {
        allow read:   if isSignedIn();
        allow create, update: if isSignedIn()
                      && voterUid == request.auth.uid
                      && request.resource.data.vote in [-1, 0, 1];
        allow delete: if isSignedIn() && voterUid == request.auth.uid;
      }
    }

    // ── forum_posts ──────────────────────────────────────────────────
    // Threaded discussion under /community. Top-level threads have
    // parentId == null; replies have parentId == <thread doc id>.
    // Anyone authenticated can read. Only the author can write/delete
    // the thread/reply itself. Vote counts on the parent doc are
    // updatable by anyone signed in (same pattern as shared_cases).
    function forumOnlyVoteFieldsChanged() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['voteScore', 'voteCount', 'replyCount']);
    }
    match /forum_posts/{postId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && incomingIsAuthor()
                    && (!('content' in request.resource.data)
                        || stringUnder('content', 51200));
      allow update: if isSignedIn()
                    && (
                      (isAuthor() && incomingIsAuthor()
                       && (!('content' in request.resource.data)
                           || stringUnder('content', 51200)))
                      || forumOnlyVoteFieldsChanged()
                    );
      allow delete: if isAuthor();

      match /votes/{voterUid} {
        allow read:   if isSignedIn();
        allow create, update: if isSignedIn()
                      && voterUid == request.auth.uid
                      && request.resource.data.vote in [-1, 0, 1];
        allow delete: if isSignedIn() && voterUid == request.auth.uid;
      }
    }

    // ── judge_pool ───────────────────────────────────────────────────
    // Anyone authenticated can read. Users can only write their own entries.
    match /judge_pool/{docId} {
      allow read:  if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── live_debates ─────────────────────────────────────────────────
    // Anyone authenticated can read. Only the creator can delete.
    match /live_debates/{debateId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.creatorUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
                    && resource.data.creatorUid == request.auth.uid;
    }

    // ── live_rounds ──────────────────────────────────────────────────
    // Per-room synced state for the AI-judged 2-human round flow:
    // motion, format, speaker names + UIDs, completed speech log,
    // current speech index, and the AI ballot once generated. Doc ID
    // is the deterministic room slug (DebateAI-<challengeId> or a
    // randomly-generated room name shared via URL).
    //
    // Read = any signed-in user (links are shared between speakers,
    // and we don't have a backend introduction step yet so the URL is
    // the entry control). Update = any signed-in user — the
    // participants discover each other dynamically by both landing on
    // the same URL. Tighten to participant-only writes once we wire
    // the server-side challenge accept flow.
    match /live_rounds/{roomId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && stringUnder('motion', 4096);

      // The consent map can only be touched by the consenting user
      // for their own UID key. Computes the affected keys of the
      // leaderboardConsent map between old and new doc state and
      // requires every changed key to equal the writer's auth.uid.
      // No leaderboardConsent change at all → returns true so it
      // doesn't block currentTimer / speech-log updates.
      function leaderboardConsentChangeIsOwnUid() {
        let oldMap = resource.data.get('leaderboardConsent', {});
        let newMap = request.resource.data.get('leaderboardConsent', {});
        let changed = newMap.diff(oldMap).affectedKeys();
        return changed.size() == 0 || changed.hasOnly([request.auth.uid]);
      }

      // Participant-only writes once the round has both UIDs locked
      // in (i.e., a posted+accepted challenge). Spectators land here
      // signed-in but match neither side, so they can read the round
      // but can't mutate it. Plus: even between participants, the
      // leaderboardConsent map is per-UID — neither side can flip
      // the other's consent flag to bypass dual consent.
      // Legacy rounds without proUid/conUid (direct-link/local-only
      // flows) keep the open update so they don't break.
      allow update: if isSignedIn()
                    && leaderboardConsentChangeIsOwnUid()
                    && (
                      !('proUid' in resource.data)
                      || !('conUid' in resource.data)
                      || resource.data.proUid == request.auth.uid
                      || resource.data.conUid == request.auth.uid
                    );
      allow delete: if false;
    }

    // ── live_challenges ──────────────────────────────────────────────
    // Cross-user challenge board — replaces the localStorage-only
    // /live.html state. Doc has: posterUid, motion, format, side,
    // scheduledAt, reveal, handle, etc. Anyone signed in can read
    // (so the board lists challenges across users). Only the poster
    // can delete their own challenge.
    match /live_challenges/{challengeId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.posterUid == request.auth.uid
                    && stringUnder('motion', 1024);
      allow update: if isSignedIn();
      allow delete: if isSignedIn()
                    && resource.data.posterUid == request.auth.uid;
    }

    // ── saved_rounds ─────────────────────────────────────────────────
    // User saves a completed live round to their record (motion,
    // format, ballot, speeches). Doc ID = uid + '_' + room so the
    // same user re-saving the same round just updates the doc
    // instead of creating duplicates. Reads + writes scoped to the
    // owning user.
    match /saved_rounds/{docId} {
      allow read:   if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // ── referral_credits ─────────────────────────────────────────────
    // Server-side only. Deny all client access.
    match /referral_credits/{docId} {
      allow read, write: if false;
    }

    // ── learning_insights ────────────────────────────────────────────
    // Users can only write their own insights.
    match /learning_insights/{docId} {
      allow read:   if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── learning_counters ────────────────────────────────────────────
    // Doc ID = uid. Users can only read/write their own counter doc.
    match /learning_counters/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ── teams ────────────────────────────────────────────────────────
    // Members can read; only owner can write the team doc.
    // Inlined ownership check (was isTeamOwner/isTeamMember helpers, but
    // isTeamMember referenced an undefined getTeamMemberByQuery and the
    // helpers added no clarity over a direct ownerUid comparison).
    match /teams/{teamId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.ownerUid == request.auth.uid;

      // members subcollection
      match /members/{memberId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
      }

      // invites subcollection
      match /invites/{inviteId} {
        allow read:   if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
      }

      // pendingInvites subcollection (alias kept for backward compat)
      match /pendingInvites/{inviteId} {
        allow read:   if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
        allow create: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow update: if isSignedIn()
                      && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid;
        allow delete: if isSignedIn()
                      && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerUid == request.auth.uid
                          || resource.data.email == request.auth.token.email);
      }
    }

    // ── team_members (top-level collection) ──────────────────────────
    // Server-managed primarily, but allow reads for team context.
    match /team_members/{docId} {
      allow read:  if isSignedIn();
      allow write: if false; // server-side only via Admin SDK
    }

    // ── usage_logs ───────────────────────────────────────────────────
    // Server-side only.
    match /usage_logs/{docId} {
      allow read, write: if false;
    }

    // ── debate_rounds ────────────────────────────────────────────────
    // Per-user history of completed AI rounds (motion, format, side, log,
    // feedback, ballot, speakerPoints). Doc ID convention: `${uid}_${roundId}`
    // so the same user re-saving the same round just merges instead of
    // creating duplicates. Reads + writes scoped to the owning user — these
    // are private histories, not the public leaderboard.
    match /debate_rounds/{docId} {
      allow read:   if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
      allow create: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*')
                    && stringUnder('motion', 4096);
      allow update: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
      allow delete: if isSignedIn()
                    && docId.matches('^' + request.auth.uid + '_.*');
    }

    // ── leaderboard_entries ──────────────────────────────────────────
    // Slim, denormalized public board of completed-round results.
    // Public read so the /leaderboard page works for anonymous visitors
    // (it's a sign-in driver — users should see the board first, then
    // be prompted to claim their spot). Writes are owner-only and the
    // doc must contain the writer's uid so spoofing other users is
    // impossible. Doc ID convention: `${uid}_${roundId}` to match the
    // existing debate_rounds convention.
    match /leaderboard_entries/{docId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && stringUnder('motion', 1024)
                    && stringUnder('displayName', 100);
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
    }

    // ── Default deny ─────────────────────────────────────────────────
    // Any collection not explicitly listed above is denied.
  }
}
