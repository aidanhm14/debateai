{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Netlify Dev (full stack: static + functions)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "netlify-cli", "dev", "--framework", "#static", "--dir", "app", "--offline"],
      "port": 8888,
      "autoPort": true
    },
    {
      "name": "Static (python http.server, app/)",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "0", "--directory", "app"],
      "port": 0,
      "autoPort": true
    },
    {
      "name": "Vite (app/ only, no Netlify functions)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "app", "run", "dev"],
      "port": 5173,
      "autoPort": true
    }
  ]
}
